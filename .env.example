# GHL Account Config
GHL_LOCATION_ID=your-location-id
GHL_COMPANY_ID=your-company-id
GHL_USER_ID=your-user-id
GHL_PARENT_FOLDER=

# Reusable campaign defaults
CAMPAIGN_NAME=Example Follow-Up Campaign
CAMPAIGN_BUSINESS_NAME=Your Business
CAMPAIGN_SENDER_NAME=Your Team
CAMPAIGN_SERVICE_CATEGORY=your services

# Optional webinar-funnel overrides
# CAMPAIGN_WEBINAR_TITLE=The Growth System Workshop
# CAMPAIGN_WEBINAR_DAY=Thursday
# CAMPAIGN_WEBINAR_TIME=7 PM ET
# CAMPAIGN_WEBINAR_LINK={{custom_values.webinar_link}}
# CAMPAIGN_OFFER_NAME=Implementation Program
# CAMPAIGN_PRICE_TEXT=your enrollment option
# CAMPAIGN_DEADLINE_TEXT=Sunday at midnight
# CAMPAIGN_TAG_PREFIX=webinar

# Auth (pick one)
# Option A: Your own token server
GHL_TOKEN_SERVER=https://your-worker.your-subdomain.workers.dev
GHL_ADMIN_PIN=your-pin

# Option B: Firebase refresh token (from Chrome DevTools)
# GHL_FIREBASE_REFRESH_TOKEN=your-refresh-token

# Option C: Direct token (expires in 1 hour)
# GHL_FIREBASE_TOKEN=eyJhbG...
