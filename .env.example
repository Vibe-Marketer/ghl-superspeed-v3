# GHL Account Config
GHL_LOCATION_ID=your-location-id
GHL_COMPANY_ID=your-company-id
GHL_USER_ID=your-user-id
GHL_PARENT_FOLDER=

# Auth (pick one)
# Option A: Your own token server
GHL_TOKEN_SERVER=https://your-worker.your-subdomain.workers.dev
GHL_ADMIN_PIN=your-pin

# Option B: Firebase refresh token (from Chrome DevTools)
# GHL_FIREBASE_REFRESH_TOKEN=your-refresh-token

# Option C: Direct token (expires in 1 hour)
# GHL_FIREBASE_TOKEN=eyJhbG...
